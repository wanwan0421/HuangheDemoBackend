PORT=3000
mongodbUrl=mongodb://127.0.0.1:27017/huanghe-demo
agentUrl=http://localhost:8000/api/agent
AGENT_INTERNAL_TOKEN=change-me

# Shared model configuration
LLM_PROVIDER=openai_compat
LLM_CHAT_MODEL=qwen-plus
LLM_EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=10
OPENAI_COMPAT_API_KEY=your-api-key
OPENAI_COMPAT_BASE_URL=https://your-openai-compatible-endpoint/v1

# NestJS GenAI service
GENAI_PROVIDER=openai_compat
GENAI_API_KEY=
GENAI_BASE_URL=
GENAI_CHAT_MODEL=
GENAI_EMBEDDING_MODEL=
GENAI_EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
GENAI_EMBEDDING_BATCH_SIZE=
GENAI_PROXY_URL=

# Google fallback
GOOGLE_API_KEY=

# Per-agent overrides
TASK_AGENT_PROVIDER=
TASK_AGENT_MODEL=
TASK_AGENT_API_KEY=
TASK_AGENT_BASE_URL=

LIGHT_DATA_SCAN_PROVIDER=
LIGHT_DATA_SCAN_MODEL=
LIGHT_DATA_SCAN_API_KEY=
LIGHT_DATA_SCAN_BASE_URL=

DATA_REFINE_AGENT_PROVIDER=
DATA_REFINE_AGENT_MODEL=
DATA_REFINE_AGENT_API_KEY=
DATA_REFINE_AGENT_BASE_URL=

ALIGNMENT_AGENT_MODEL=
ALIGNMENT_AGENT_API_KEY=
ALIGNMENT_AGENT_BASE_URL=

DATA_SCAN_AGENT_MODEL=
DATA_SCAN_AGENT_API_KEY=
DATA_SCAN_AGENT_BASE_URL=

EXECUTE_AGENT_MODEL=
EXECUTE_AGENT_API_KEY=
EXECUTE_AGENT_BASE_URL=

MODEL_RECOMMEND_CHAT_MODEL=
MODEL_RECOMMEND_EMBEDDING_MODEL=
MODEL_RECOMMEND_API_KEY=
MODEL_RECOMMEND_BASE_URL=

MEMORY_AGENT_API_KEY=
